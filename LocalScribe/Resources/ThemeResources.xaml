<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="AppCornerRadius">8</x:Double>
    <Thickness x:Key="AppPagePadding">24</Thickness>
    <x:Double x:Key="AppSectionSpacing">16</x:Double>

    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#1A3B82F6" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#1AFFFFFF" />

</ResourceDictionary>