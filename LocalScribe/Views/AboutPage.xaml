<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LocalScribe.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel
            Padding="{StaticResource AppPagePadding}"
            MaxWidth="760"
            Spacing="{StaticResource AppSectionSpacing}">

            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource PageTitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />
                <TextBlock
                    FontSize="14"
                    Opacity="0.72"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
            </StackPanel>

            <Border Style="{StaticResource PlaceholderCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Image
                            x:Name="AppLogoImage"
                            Width="56"
                            Height="56" />
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.AppName, Mode=OneWay}" />
                            <TextBlock
                                Opacity="0.75"
                                Text="{x:Bind ViewModel.Tagline, Mode=OneWay}" />
                            <TextBlock
                                FontSize="12"
                                Opacity="0.6"
                                Text="{x:Bind ViewModel.VersionLabel, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock
                        LineHeight="24"
                        Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PlaceholderCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="HIGHLIGHTS" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Highlights, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <StackPanel
                                    Margin="0,0,0,8"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="12"
                                        Foreground="{StaticResource SuccessBrush}"
                                        Glyph="&#xE73E;" />
                                    <TextBlock
                                        Width="640"
                                        LineHeight="22"
                                        Text="{Binding}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PlaceholderCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="UPDATES" />
                    <TextBlock
                        Text="{x:Bind ViewModel.UpdateStatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            Content="Check for updates" />
                        <Button
                            Command="{x:Bind ViewModel.DownloadUpdateCommand}"
                            Content="Update now"
                            Style="{StaticResource AccentButtonStyle}" />
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsCheckingForUpdates, Mode=OneWay}" />
                    </StackPanel>
                    <TextBlock
                        FontSize="12"
                        Opacity="0.65"
                        Text="SonicScribe downloads updates from GitHub. Run the new installer to update — your settings are kept."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PlaceholderCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="REQUIREMENTS" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Requirements, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <StackPanel
                                    Margin="0,0,0,8"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="12"
                                        Glyph="&#xE946;" />
                                    <TextBlock
                                        Width="640"
                                        LineHeight="22"
                                        Text="{Binding}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>