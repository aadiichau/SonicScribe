<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LocalScribe.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LocalScribe.ViewModels"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Page.Resources>
        <Style TargetType="NavigationView">
            <Setter Property="IsBackButtonVisible" Value="Collapsed" />
            <Setter Property="IsSettingsVisible" Value="False" />
            <Setter Property="PaneDisplayMode" Value="Left" />
            <Setter Property="OpenPaneLength" Value="280" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Page.Resources>

    <Grid>
        <NavigationView
            x:Name="NavView"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="ShellPage_Loaded">

            <NavigationView.PaneHeader>
                <StackPanel Margin="12,8,12,16" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                    <Image
                        x:Name="AppLogoImage"
                        Width="28"
                        Height="28" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="SonicScribe" />
                    </StackPanel>
                    <TextBlock
                        FontSize="12"
                        Opacity="0.7"
                        Text="Whisper · Local · Unlimited" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="transcribe">
                    <NavigationViewItem.Content>
                        <TextBlock Text="Transcribe" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE720;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="history">
                    <NavigationViewItem.Content>
                        <TextBlock Text="History" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Settings"
                    Icon="Setting"
                    Tag="settings" />
                <NavigationViewItem Tag="about">
                    <NavigationViewItem.Content>
                        <TextBlock Text="About" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="12,8" Spacing="8">
                    <Button
                        x:Name="PaneAddFilesButton"
                        HorizontalAlignment="Stretch"
                        Click="PaneAddFiles_Click"
                        Content="Add files"
                        Style="{StaticResource AccentButtonStyle}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="#FF94A3B8"
                        Text="Add audio/video to transcribe"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.Content>
                <Frame
                    x:Name="ContentFrame"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <Frame.ContentTransitions>
                        <TransitionCollection>
                            <NavigationThemeTransition />
                        </TransitionCollection>
                    </Frame.ContentTransitions>
                </Frame>
            </NavigationView.Content>
        </NavigationView>

        <Border
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,8,24,0"
            Style="{StaticResource AccentPillBorderStyle}"
            Visibility="{x:Bind ViewModel.GpuBadgeVisibility, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Grid Width="8" Height="8">
                    <Ellipse
                        Fill="{StaticResource SuccessBrush}"
                        Visibility="{x:Bind ViewModel.GpuAcceleratedVisibility, Mode=OneWay}" />
                    <Ellipse
                        Fill="#F59E0B"
                        Visibility="{x:Bind ViewModel.GpuNotAcceleratedVisibility, Mode=OneWay}" />
                </Grid>
                <TextBlock
                    FontFamily="Consolas"
                    FontSize="12"
                    Text="{x:Bind ViewModel.GpuLabel, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>