<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LocalScribe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LocalScribe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SonicScribe"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="SonicScribe" />

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <Grid
            x:Name="StartupOverlay"
            Grid.Row="1"
            Background="#CC101010">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="420"
                MaxWidth="520"
                Spacing="16">
                <ProgressRing
                    x:Name="StartupProgressRing"
                    Width="48"
                    Height="48"
                    IsActive="True" />
                <TextBlock
                    x:Name="StartupTitleText"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Starting SonicScribe..." />
                <TextBlock
                    x:Name="StartupSubtitleText"
                    HorizontalAlignment="Center"
                    Opacity="0.7"
                    Text="Loading settings, history, and GPU profile"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />
                <StackPanel
                    x:Name="StartupProgressPanel"
                    Spacing="8"
                    Visibility="Collapsed">
                    <ProgressBar
                        x:Name="StartupProgressBar"
                        Maximum="100"
                        Value="0" />
                    <TextBlock
                        x:Name="StartupProgressLabel"
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Opacity="0.75"
                        Text="0%" />
                    <TextBlock
                        x:Name="StartupReassuranceText"
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Opacity="0.6"
                        Text="Large downloads can pause between chunks — don't panic, progress will continue."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>